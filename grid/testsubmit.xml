<?xml version="1.0"?>

<!--
  ============================================================================
  REAL working grid-submission XML (NuGraph via EAF), with user-specific paths
  turned into the &user; entity so you DON'T overwrite anyone else's files.

  >>> BEFORE RUNNING: set  <!ENTITY user "..."> to YOUR Fermilab username, and
      check the outdir / workdir / tarball paths point at YOUR areas. <<<

  Drives project.py:
    project.py --xml testsubmit.xml --stage ng2test --submit
  See grid/README.md and docs/05_grid_submission.md.
  ============================================================================
-->

<!DOCTYPE project [
<!ENTITY user "CHANGEME_username">          <!-- TODO: your username; do not leave as CHANGEME_username -->
<!ENTITY release "v10_06_00_01p01">
<!ENTITY releasetag "e26:prof">
<!ENTITY name "ng2_eaf_test">
<!ENTITY file_type "mc">
<!ENTITY run_type "physics">
<!ENTITY my_version "v1">
]>

<project name="&name;">

  <group>icarus</group>
  <os>SL7</os>

  <!-- total events to process -->
  <numevents>200</numevents>

  <!-- run only on Fermigrid -->
  <resource>DEDICATED,OPPORTUNISTIC</resource>

  <larsoft>
    <tag>&release;</tag>
    <qual>&releasetag;</qual>
    <!-- your code tarball (build it from your dev area; see grid/README.md) -->
    <local>/pnfs/icarus/resilient/users/&user;/tarballs/icaruscode-workingarea-&release;.tar.gz</local>
  </larsoft>

  <stage name="ng2test">
    <inputlist>fileLists/files_clean.list</inputlist>

    <fcl>
        testinference_slice_icarus_triton_eaf.fcl
    </fcl>

    <outdir>/pnfs/icarus/scratch/users/&user;/&release;/ng2_eaf_&my_version;/test_1job_5files</outdir>
    <workdir>/pnfs/icarus/resilient/users/&user;/workdirs/ng2test</workdir>

    <numjobs>1</numjobs>
    <maxfilesperjob>5</maxfilesperjob>

    <datatier>generated</datatier>
    <memory>10000</memory>
    <disk>100GB</disk>

    <jobsub> --expected-lifetime=1h --generate-email-summary -l +SingularityImage=\"/cvmfs/singularity.opensciencegrid.org/fermilab/fnal-wn-sl7:latest\" --append_condor_requirements='(TARGET.HAS_SINGULARITY=?=true)' </jobsub>
  </stage>

  <filetype>&file_type;</filetype>
  <runtype>&run_type;</runtype>

</project>
